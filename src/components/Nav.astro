---
const base = import.meta.env.BASE_URL;
---
<header class="nav" id="nav">
  <a class="brand" href="#hero" aria-label="TAKAKI.ai home">
    <img src={`${base}kamon.png`} alt="" width="34" height="34" class="brand__mark" />
    <span class="brand__name">TAKAKI<span class="brand__dot">.</span>ai</span>
  </a>

  <nav class="nav__links" id="navLinks" aria-label="primary">
    <a href="#concept" data-i18n="nav.concept">流儀</a>
    <a href="#contact" data-i18n="nav.contact">コンタクト</a>
  </nav>

  <button class="lang-toggle" id="langToggle" type="button" aria-label="Switch language">
    <span class="lang-toggle__opt is-active" data-lang-opt="ja">日本語</span>
    <span class="lang-toggle__sep">/</span>
    <span class="lang-toggle__opt" data-lang-opt="en">EN</span>
  </button>

  <button class="nav__burger" id="burger" type="button" aria-label="Menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</header>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.85rem clamp(1.25rem, 5vw, 3rem);
    background: rgba(247, 243, 234, 0);
    backdrop-filter: blur(0px);
    transition: background 0.4s, backdrop-filter 0.4s, border-color 0.4s;
    border-bottom: 1px solid transparent;
  }
  .nav.is-scrolled {
    background: rgba(247, 243, 234, 0.9);
    backdrop-filter: blur(14px);
    border-bottom-color: rgba(200, 162, 74, 0.22);
  }
  .brand { display: flex; align-items: center; gap: 0.6rem; }
  .brand__mark { border-radius: 7px; object-fit: cover; }
  .brand__name {
    font-family: "Cormorant Garamond", serif;
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    color: #fff;
    transition: color 0.4s;
  }
  .nav.is-scrolled .brand__name { color: #16223d; }
  .brand__dot { color: #c8a24a; }

  .nav__links {
    display: flex;
    gap: 1.6rem;
    margin-left: auto;
    font-size: 0.86rem;
  }
  .nav__links a {
    position: relative;
    color: rgba(247, 243, 234, 0.9);
    transition: color 0.4s, opacity 0.25s;
  }
  .nav.is-scrolled .nav__links a { color: #2a2f3a; }
  .nav__links a::after {
    content: "";
    position: absolute;
    left: 0; bottom: -5px;
    width: 0; height: 1.5px;
    background: #a8842f;
    transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav__links a:hover::after { width: 100%; }

  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: none;
    border: 1px solid rgba(200, 162, 74, 0.4);
    border-radius: 999px;
    padding: 0.35rem 0.85rem;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.76rem;
    color: rgba(247, 243, 234, 0.92);
    transition: border-color 0.3s, color 0.4s;
  }
  .nav.is-scrolled .lang-toggle { color: #2a2f3a; }
  .lang-toggle:hover { border-color: #c8a24a; }
  .lang-toggle__opt { opacity: 0.55; transition: opacity 0.25s, color 0.25s; }
  .lang-toggle__opt.is-active { opacity: 1; color: #c8a24a; font-weight: 700; }
  .lang-toggle__sep { opacity: 0.4; }

  .nav__burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 6px;
  }
  .nav__burger span {
    width: 24px; height: 2px;
    background: #f7f3ea;
    transition: 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav.is-scrolled .nav__burger span { background: #16223d; }
  .nav__burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav__burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 860px) {
    .nav__links {
      position: fixed;
      top: 0;
      right: 0;
      left: auto;
      height: 100vh;
      height: 100dvh;
      width: min(78vw, 320px);
      flex-direction: column;
      justify-content: center;
      gap: 2rem;
      padding: 2rem;
      background: rgba(13, 23, 41, 0.97);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      transform: translateX(100%);
      transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1);
      font-size: 1.1rem;
      overflow-y: auto;
    }
    .nav__links a,
    .nav.is-scrolled .nav__links a { color: #f7f3ea; }
    .nav__links.is-open { transform: none; }
    .nav__burger { display: flex; order: 3; }
    .lang-toggle { margin-left: auto; }
  }
</style>
